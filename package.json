{
  "name": "@edison/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React components, design tokens, and client utilities for Edison Watch.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edison-Watch/shared.git"
  },
  "homepage": "https://github.com/Edison-Watch/shared#readme",
  "bugs": {
    "url": "https://github.com/Edison-Watch/shared/issues"
  },
  "keywords": [
    "edison-watch",
    "react",
    "design-system",
    "mcp",
    "security"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.js",
      "require": "./dist/ui/*.cjs"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js",
      "require": "./dist/hooks/*.cjs"
    },
    "./agent-registry": {
      "types": "./dist/agent-registry/index.d.ts",
      "import": "./dist/agent-registry/index.js",
      "require": "./dist/agent-registry/index.cjs"
    },
    "./animations": {
      "types": "./dist/animations/index.d.ts",
      "import": "./dist/animations/index.js",
      "require": "./dist/animations/index.cjs"
    },
    "./svg": {
      "types": "./dist/svg/index.d.ts",
      "import": "./dist/svg/index.js",
      "require": "./dist/svg/index.cjs"
    },
    "./theme/tokens.css": "./src/theme/tokens.css"
  },
  "files": [
    "dist",
    "src/theme/tokens.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "npx playwright test --config playwright.config.ts",
    "test:visual:update": "npx playwright test --config playwright.config.ts --update-snapshots"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.90.0",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-onboarding": "^10.2.12",
    "@storybook/react-vite": "^10.2.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "storybook": "^10.2.12",
    "tsup": "^8.5.0",
    "typescript": "5.7",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.90.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router": "^7.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
