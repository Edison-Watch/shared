{
  "name": "@edison/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./crypto": {
      "types": "./src/crypto/index.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "import": "./dist/ui/*.js",
      "require": "./dist/ui/*.cjs"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "import": "./dist/hooks/*.js",
      "require": "./dist/hooks/*.cjs"
    },
    "./theme/tokens.css": "./src/theme/tokens.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "npx playwright test --config playwright.config.ts",
    "test:visual:update": "npx playwright test --config playwright.config.ts --update-snapshots"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-onboarding": "^10.2.12",
    "@storybook/react-vite": "^10.2.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "storybook": "^10.2.12",
    "tsup": "^8.5.0",
    "typescript": "5.7",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.90.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "react-router": {
      "optional": true
    }
  }
}
