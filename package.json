{
  "name": "@edison/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React components, design tokens, and client utilities for Edison Watch.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edison-Watch/shared.git"
  },
  "homepage": "https://github.com/Edison-Watch/shared#readme",
  "bugs": {
    "url": "https://github.com/Edison-Watch/shared/issues"
  },
  "keywords": [
    "edison-watch",
    "react",
    "design-system",
    "mcp",
    "security"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth/index.d.mts",
        "default": "./dist/auth/index.mjs"
      },
      "require": {
        "types": "./dist/auth/index.d.cts",
        "default": "./dist/auth/index.cjs"
      }
    },
    "./crypto": {
      "import": {
        "types": "./dist/crypto/index.d.mts",
        "default": "./dist/crypto/index.mjs"
      },
      "require": {
        "types": "./dist/crypto/index.d.cts",
        "default": "./dist/crypto/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config/index.d.mts",
        "default": "./dist/config/index.mjs"
      },
      "require": {
        "types": "./dist/config/index.d.cts",
        "default": "./dist/config/index.cjs"
      }
    },
    "./ui": {
      "import": {
        "types": "./dist/ui/index.d.mts",
        "default": "./dist/ui/index.mjs"
      },
      "require": {
        "types": "./dist/ui/index.d.cts",
        "default": "./dist/ui/index.cjs"
      }
    },
    "./ui/*": {
      "import": {
        "types": "./dist/ui/*.d.mts",
        "default": "./dist/ui/*.mjs"
      },
      "require": {
        "types": "./dist/ui/*.d.cts",
        "default": "./dist/ui/*.cjs"
      }
    },
    "./hooks/*": {
      "import": {
        "types": "./dist/hooks/*.d.mts",
        "default": "./dist/hooks/*.mjs"
      },
      "require": {
        "types": "./dist/hooks/*.d.cts",
        "default": "./dist/hooks/*.cjs"
      }
    },
    "./agent-registry": {
      "import": {
        "types": "./dist/agent-registry/index.d.mts",
        "default": "./dist/agent-registry/index.mjs"
      },
      "require": {
        "types": "./dist/agent-registry/index.d.cts",
        "default": "./dist/agent-registry/index.cjs"
      }
    },
    "./animations": {
      "import": {
        "types": "./dist/animations/index.d.mts",
        "default": "./dist/animations/index.mjs"
      },
      "require": {
        "types": "./dist/animations/index.d.cts",
        "default": "./dist/animations/index.cjs"
      }
    },
    "./svg": {
      "import": {
        "types": "./dist/svg/index.d.mts",
        "default": "./dist/svg/index.mjs"
      },
      "require": {
        "types": "./dist/svg/index.d.cts",
        "default": "./dist/svg/index.cjs"
      }
    },
    "./theme/tokens.css": "./src/theme/tokens.css"
  },
  "files": [
    "dist",
    "src/theme/tokens.css"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "npx playwright test --config playwright.config.ts",
    "test:visual:update": "npx playwright test --config playwright.config.ts --update-snapshots"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-onboarding": "^10.2.12",
    "@storybook/react-vite": "^10.2.12",
    "@supabase/supabase-js": "^2.90.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.18.0",
    "prettier": "^3.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^8.0.1",
    "storybook": "^10.2.12",
    "tsdown": "^0.22.3",
    "typescript": "6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.90.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router": "^7.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
